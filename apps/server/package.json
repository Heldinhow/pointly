{
	"name": "server",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"description": "Pointly backend — Bun + Hono + WebSocket",
	"main": "src/index.ts",
	"scripts": {
		"dev": "bun run --hot src/index.ts",
		"start": "bun run src/index.ts",
		"build": "bun build src/index.ts --target=bun --outdir=dist",
		"test": "bun test src/",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"hono": "^4.6.14",
		"@planning-poker/shared": "workspace:*",
		"zod": "^3.24.1"
	},
	"devDependencies": {
		"bun-types": "^1.1.14",
		"typescript": "^5.7.2"
	}
}
